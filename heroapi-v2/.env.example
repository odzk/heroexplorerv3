# ============================================================================
# Hero Explorer API v2 — environment template
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# ============================================================================

# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL) ───────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/heroexplorer?schema=public

# ── Auth (JWT) ──────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── CORS (comma-separated origins) ──────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Viator Partner API ──────────────────────────────────
VIATOR_API_KEY=
VIATOR_API_URL=https://api.sandbox.viator.com/partner
# Production: https://api.viator.com/partner
VIATOR_CURRENCY=AUD

# ── Redis (optional — enables Viator taxonomy caching) ──
# REDIS_URL=redis://localhost:6379

# ── Stripe (optional — required for /payments + checkout) ─
# STRIPE_SECRET_KEY=sk_test_...

# ── Email / SMTP (optional — required for email flows) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=hello@heroexplorer.com
# SMTP_PASS=
MAIL_FROM=Hero Explorer <hello@heroexplorer.com>
ADMIN_NOTIFY_EMAILS=hello@heroexplorer.com
APP_PUBLIC_URL=https://www.heroexplorer.com

# ── AWS S3 (optional — required for logo upload) ────────
AWS_REGION=ap-southeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=heroexplorer
AWS_S3_PREFIX=logo

# ── DigitalOcean DNS (optional — subdomain provisioning) ─
# DIGITALOCEAN_TOKEN=
DIGITALOCEAN_API_URL=https://api.digitalocean.com/v2/
ROOT_DOMAIN=heroexplorer.com
