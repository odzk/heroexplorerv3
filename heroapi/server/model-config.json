{
  "_meta": {
    "sources": [
      "loopback/common/models",
      "loopback/server/models",
      "../common/models",
      "../common/models/booking",
      "../common/models/sample",
      "../common/models/product",
      "../common/models/user-content",
      "../common/models/taxonomy",
      "../common/models/attraction",
      "../common/models/recommendation",
      "../common/models/customization",
      "../common/models/seo",
      "./models"
    ],
    "mixins": [
      "loopback/common/mixins",
      "loopback/server/mixins",
      "../node_modules/loopback-ds-timestamp-mixin",
      "../common/mixins",
      "./mixins"
    ]
  },
  "User": {
    "dataSource": "herodb",
    "public": false
  },
  "AccessToken": {
    "dataSource": "herodb",
    "public": false
  },
  "ACL": {
    "dataSource": "herodb",
    "public": false
  },
  "RoleMapping": {
    "dataSource": "herodb",
    "public": false,
    "options": {
      "strictObjectIDCoercion": true
    }
  },
  "Role": {
    "dataSource": "herodb",
    "public": false
  },
  "Page": {
    "dataSource": "herodb",
    "public": false
  },
  "Project": {
    "dataSource": "herodb",
    "public": false
  },
  "Workspace": {
    "dataSource": "herodb",
    "public": false
  },
  "Product": {
    "dataSource": "herodb",
    "public": true
  },
