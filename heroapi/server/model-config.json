  "HeroBooking": {
    "dataSource": "herodb",
    "public": true,
    "options": {
      "remoting": {
        "sharedMethods": {
          "*": false,
          "cancelBookingDB": true,
          "getListAllBookingAdmin": true,
          "getListAllPrevBookingAdmin": true,
          "getListAllBooking": true,
          "getListAllBookingPrev": true,
          "getListMyBooking": true,
          "listPastBooking": true,
          "getCancelBookingReasons": true,
          "cancelABooking": true,
          "getVoucherData": true,
          "requestEditBooking": true,
          "getReportBookings": true,
          "downloadReportBookings": true
        }
      }
    }
  },
  "HeroBookingDetail": {
    "dataSource": "herodb",
    "public": true
  },
  "Booker": {
    "dataSource": "herodb",
    "public": true,
    "options": {
      "remoting": {
        "sharedMethods": {
          "*": false,
          "getBookerId": true
        }
      }
    }
  },
  "HeroBookingTraveller": {
    "dataSource": "herodb",
    "public": true
  },
  "HeroBookingQuestion": {
    "dataSource": "herodb",
